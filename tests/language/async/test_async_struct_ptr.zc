struct String {
    data: char*;
}

struct StringOfString {
    str: String*;
}

async fn fetch_struct() -> String {
    let str = String { data: malloc(sizeof(char) * 6) };
    str.data = "World\0";
    return str;
}

async fn fetch_struct2() -> StringOfString* {
    let str_ptr: String* = malloc(sizeof(String));
    *str_ptr = await fetch_struct();
    let ptr: StringOfString* = malloc(sizeof(StringOfString));
    *ptr = StringOfString { str: str_ptr };
    return ptr;
}

test "async_returns_struct_ptr" {
    let result = await fetch_struct2();
    assert(result.str.data == "World", "failed to return struct of struct");
}

impl Drop for String {
    fn drop(self) { free(self.data); self.data = NULL; }
}

impl Drop for StringOfString {
    fn drop(self) { self.str.drop(); self.str = NULL; }
}